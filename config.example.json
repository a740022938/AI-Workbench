        "enable_openclaw": true
    },
    "training": {
        "data": "./data.yaml",
        "model": "yolo26n.pt",
        "epochs": 100,
        "batch_size": 16,
        "imgsz": 640,
        "device": "0",
        "project": "./runs/train",
        "name": "exp"
