{
    "paths": {
        "image_dir": "./images",
        "label_dir": "./labels",
        "bad_cases_dir": "./bad_cases",
        "model_path": "",
        "video_dir": "",
        "output_dataset_dir": "./dataset_output"
    },
    "model": {
        "conf": 0.25,
        "iou": 0.5,
        "imgsz": 640
    },
