"""
操作决策规范 v1 - 轻量规则模块

为 OpenClaw 分身桥接层提供动作执行策略和风险控制。
"""

from enum import Enum
from typing import Dict, Any, Optional


class RiskLevel(Enum):
    """风险等级"""
    LOW = "low"        # 低风险：只读、视图切换等
    MEDIUM = "medium"  # 中风险：数据修改、文件写入等
    HIGH = "high"      # 高风险：数据删除、覆盖等


class ExecutionMode(Enum):
    """执行模式"""
    DIRECT = "direct"      # 直接执行（低风险动作）
    CHOOSE = "choose"      # 提供选项让用户选择
    PREVIEW = "preview"    # 先预览效果，再确认执行
    BACKUP = "backup"      # 执行前自动备份
    CONFIRM = "confirm"    # 需要用户明确确认


class ActionPolicy:
    """动作策略定义"""
    
    def __init__(
        self,
        action_name: str,
        risk_level: RiskLevel,
        execution_mode: ExecutionMode,
        needs_confirmation: bool = False,
        needs_backup: bool = False,
        summary_template: str = "",
        description: str = "",
        allowed_contexts: Optional[list] = None
    ):
        self.action_name = action_name
        self.risk_level = risk_level
        self.execution_mode = execution_mode
        self.needs_confirmation = needs_confirmation
        self.needs_backup = needs_backup
        self.summary_template = summary_template
        self.description = description
        self.allowed_contexts = allowed_contexts or []
    
    def to_dict(self) -> Dict[str, Any]:
        """转换为字典格式"""
        return {
            "action_name": self.action_name,
            "risk_level": self.risk_level.value,
            "execution_mode": self.execution_mode.value,
            "needs_confirmation": self.needs_confirmation,
            "needs_backup": self.needs_backup,
            "summary_template": self.summary_template,
            "description": self.description,
            "allowed_contexts": self.allowed_contexts
        }
    
    def get_summary(self, **kwargs) -> str:
        """获取动作执行摘要"""
        if self.summary_template:
            try:
                return self.summary_template.format(**kwargs)
            except:
                return f"执行动作: {self.action_name}"
        return f"执行动作: {self.action_name}"


