# ==================== 策略管理函数 ====================

def get_action_policy(action_name: str) -> Optional[ActionPolicy]:
    """获取指定动作的策略"""
    return ACTION_POLICIES.get(action_name)


def get_all_policies() -> Dict[str, Dict[str, Any]]:
    """获取所有动作策略（字典格式）"""
    return {name: policy.to_dict() for name, policy in ACTION_POLICIES.items()}


def get_policy_summary(action_name: str, **kwargs) -> str:
    """获取动作策略摘要"""
    policy = get_action_policy(action_name)
    if policy:
        return policy.get_summary(**kwargs)
    return f"未知动作: {action_name}"


def check_action_allowed(action_name: str, context: Dict[str, Any]) -> Dict[str, Any]:
    """
    检查动作是否允许执行
    
    返回:
        Dict: {
            "allowed": bool,
            "action_name": str,
            "policy": Dict or None,
            "reasons": List[str],
            "suggestions": List[str]
        }
    """
    policy = get_action_policy(action_name)
    
    if not policy:
        return {
            "allowed": False,
            "action_name": action_name,
            "policy": None,
            "reasons": [f"未知动作: {action_name}"],
            "suggestions": [f"支持的动作: {', '.join(ACTION_POLICIES.keys())}"]
        }
    
    # 检查上下文条件（简化版，后续可扩展）
    reasons = []
    suggestions = []
    
    # 这里可以添加更复杂的上下文检查逻辑
    # 目前只返回基本策略信息
    
    return {
        "allowed": True,  # 默认允许，实际应根据上下文判断
        "action_name": action_name,
        "policy": policy.to_dict(),
        "reasons": reasons,
        "suggestions": suggestions
    }


def get_risk_summary() -> Dict[str, Any]:
    """获取风险等级统计摘要"""
    risk_counts = {
        "low": 0,
        "medium": 0,
        "high": 0,
        "total": len(ACTION_POLICIES)
    }
    
    for policy in ACTION_POLICIES.values():
        risk_counts[policy.risk_level.value] += 1
    
    return {
        "risk_distribution": risk_counts,
        "high_risk_actions": [
            name for name, policy in ACTION_POLICIES.items()
            if policy.risk_level == RiskLevel.HIGH
        ],
        "needs_confirmation_actions": [
            name for name, policy in ACTION_POLICIES.items()
            if policy.needs_confirmation
        ],
        "needs_backup_actions": [
            name for name, policy in ACTION_POLICIES.items()
            if policy.needs_backup
        ]
    }