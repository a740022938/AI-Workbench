                    return
                with open(file_path, "r", encoding="utf-8") as f:
                    data = yaml.safe_load(f)
            else:
                messagebox.showerror("导入失败", "不支持的配置文件格式")
                return

            if not isinstance(data, dict):
                messagebox.showerror("导入失败", "配置文件内容不是字典结构")
                return

            training_data = data.get("training", data)

            if not isinstance(training_data, dict):
                messagebox.showerror("导入失败", "未找到有效的 training 配置")
                return

            if "training" not in self.config_data or not isinstance(self.config_data.get("training"), dict):
                self.config_data["training"] = {}

            self.config_data["training"].update(training_data)

            try:
                if hasattr(self, "status_var"):
                    self.status_var.set(f"已导入训练配置: {file_path}")
            except:
                pass

            training_cfg = self.config_data["training"]
            keys = ["data", "data_yaml", "model", "epochs", "batch_size", "imgsz", "device", "project", "name"]
            summary = []
            for k in keys:
                if k in training_cfg:
                    summary.append(f"{k} = {training_cfg[k]}")

            missing = []
            if not training_cfg.get("data") and not training_cfg.get("data_yaml"):
                missing.append("data 或 data_yaml")
            if not training_cfg.get("model"):
                missing.append("model")

            msg = "训练配置已导入\n\n"
            if summary:
                msg += "\n".join(summary[:12])
            else:
                msg += "未读取到常用训练参数"

            if missing:
                msg += "\n\n缺少关键项:\n" + "\n".join(missing)

