        return True

    # ==================== OpenClaw分身能力扩张v2第二刀：无弹窗框微调动作 ====================

    def move_box_by_index(self, box_index, dx, dy):
        """
        按索引移动框（相对移动）
        
        参数:
            box_index: 框的索引（0-based）
            dx: X方向移动量（归一化坐标，-1到1）
            dy: Y方向移动量（归一化坐标，-1到1）
        
        返回:
            bool: 是否成功移动
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if not (0 <= box_index < len(self.boxes)):
            self.set_status(f"状态：无效的框索引 {box_index}，有效范围 0-{len(self.boxes)-1}")
            return False
        
        # 限制移动量在合理范围内
        dx = max(-1.0, min(1.0, dx))
        dy = max(-1.0, min(1.0, dy))
        
        # 获取当前框
        box = self.boxes[box_index]
        cls_id, cx, cy, w, h = box
        
        # 计算新位置
        new_cx = max(0.0, min(1.0, cx + dx))
        new_cy = max(0.0, min(1.0, cy + dy))
        
        # 更新框位置
        self.boxes[box_index] = [cls_id, new_cx, new_cy, w, h]
        
        # 如果该框是当前选中框，刷新UI
        if self.selected_idx == box_index:
            self.refresh_box_list()
            self.redraw_boxes()
            self.update_selected_box_panel()
        
        self.set_status(f"状态：已移动框 #{box_index} (dx={dx:.3f}, dy={dy:.3f})")
        return True

    def resize_box_by_index(self, box_index, dw, dh):
        """
        按索引调整框大小（相对调整）
        
        参数:
            box_index: 框的索引（0-based）
            dw: 宽度调整量（归一化坐标，-1到1）
            dh: 高度调整量（归一化坐标，-1到1）
        
        返回:
            bool: 是否成功调整
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if not (0 <= box_index < len(self.boxes)):
            self.set_status(f"状态：无效的框索引 {box_index}，有效范围 0-{len(self.boxes)-1}")
            return False
        
        # 限制调整量在合理范围内
        dw = max(-1.0, min(1.0, dw))
        dh = max(-1.0, min(1.0, dh))
        
        # 获取当前框
        box = self.boxes[box_index]
        cls_id, cx, cy, w, h = box
        
        # 计算新大小（保持最小尺寸）
        new_w = max(0.01, min(1.0, w + dw))
        new_h = max(0.01, min(1.0, h + dh))
        
        # 更新框大小
        self.boxes[box_index] = [cls_id, cx, cy, new_w, new_h]
        
        # 如果该框是当前选中框，刷新UI
        if self.selected_idx == box_index:
            self.refresh_box_list()
            self.redraw_boxes()
            self.update_selected_box_panel()
        
        self.set_status(f"状态：已调整框 #{box_index} 大小 (dw={dw:.3f}, dh={dh:.3f})")
        return True

    def nudge_box_by_index(self, box_index, direction, amount=0.01):
        """
        按索引微调框位置（小步移动）
        
        参数:
            box_index: 框的索引（0-based）
            direction: 移动方向 ('up', 'down', 'left', 'right')
            amount: 移动量（默认0.01，归一化坐标）
        
        返回:
            bool: 是否成功微调
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if not (0 <= box_index < len(self.boxes)):
            self.set_status(f"状态：无效的框索引 {box_index}，有效范围 0-{len(self.boxes)-1}")
            return False
        
        # 根据方向计算移动量
        direction_map = {
            'up': (0, -amount),
            'down': (0, amount),
            'left': (-amount, 0),
            'right': (amount, 0)
        }
        
        if direction not in direction_map:
            self.set_status(f"状态：无效的移动方向 '{direction}'，有效方向: {', '.join(direction_map.keys())}")
            return False
        
        dx, dy = direction_map[direction]
        
        # 获取当前框
        box = self.boxes[box_index]
        cls_id, cx, cy, w, h = box
        
        # 计算新位置
        new_cx = max(0.0, min(1.0, cx + dx))
        new_cy = max(0.0, min(1.0, cy + dy))
        
        # 更新框位置
        self.boxes[box_index] = [cls_id, new_cx, new_cy, w, h]
        
        # 如果该框是当前选中框，刷新UI
        if self.selected_idx == box_index:
            self.refresh_box_list()
            self.redraw_boxes()
            self.update_selected_box_panel()
        
        self.set_status(f"状态：已微调框 #{box_index} 向{direction}移动 {amount:.3f}")
        return True

    def set_box_coords_by_index(self, box_index, cx=None, cy=None, w=None, h=None):
        """
        按索引设置框坐标（绝对设置）
        
        参数:
            box_index: 框的索引（0-based）
            cx: 新的中心X坐标（归一化，0-1）
            cy: 新的中心Y坐标（归一化，0-1）
            w: 新的宽度（归一化，0-1）
            h: 新的高度（归一化，0-1）
        
        返回:
            bool: 是否成功设置
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if not (0 <= box_index < len(self.boxes)):
            self.set_status(f"状态：无效的框索引 {box_index}，有效范围 0-{len(self.boxes)-1}")
            return False
        
        # 获取当前框
        box = self.boxes[box_index]
        cls_id, old_cx, old_cy, old_w, old_h = box
        
        # 更新坐标（只更新提供的参数）
        new_cx = cx if cx is not None else old_cx
        new_cy = cy if cy is not None else old_cy
        new_w = w if w is not None else old_w
        new_h = h if h is not None else old_h
        
        # 验证坐标范围
        new_cx = max(0.0, min(1.0, new_cx))
        new_cy = max(0.0, min(1.0, new_cy))
        new_w = max(0.01, min(1.0, new_w))
        new_h = max(0.01, min(1.0, new_h))
        
        # 更新框
        self.boxes[box_index] = [cls_id, new_cx, new_cy, new_w, new_h]
        
        # 如果该框是当前选中框，刷新UI
        if self.selected_idx == box_index:
            self.refresh_box_list()
            self.redraw_boxes()
            self.update_selected_box_panel()
        
        # 生成更新日志
        changes = []
        if cx is not None and cx != old_cx:
            changes.append(f"cx: {old_cx:.3f}→{new_cx:.3f}")
        if cy is not None and cy != old_cy:
            changes.append(f"cy: {old_cy:.3f}→{new_cy:.3f}")
        if w is not None and w != old_w:
            changes.append(f"w: {old_w:.3f}→{new_w:.3f}")
        if h is not None and h != old_h:
            changes.append(f"h: {old_h:.3f}→{new_h:.3f}")
        
        if changes:
            self.set_status(f"状态：已设置框 #{box_index} 坐标 ({', '.join(changes)})")
        else:
            self.set_status(f"状态：框 #{box_index} 坐标未变化")
        
        return True

