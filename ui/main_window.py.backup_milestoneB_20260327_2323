        self.set_status(f"状态：类别已修改为 {new_name}")

    def delete_selected_box(self):
        if self.selected_idx is None or not (0 <= self.selected_idx < len(self.boxes)):
            messagebox.showinfo("提示", "请先选中一个框。")
            return
        self.boxes.pop(self.selected_idx)
        self.selected_idx = None
        self.refresh_box_list()
        self.redraw_boxes()
        self.set_status(f"状态：已删除框，当前框数 {len(self.boxes)}")


    def export_dataset_action(self):
        output_dir = self.config_data.get("paths", {}).get("output_dataset_dir", "").strip()

        if not output_dir:
            messagebox.showwarning("提示", "请先在设置里填写输出数据集目录")
            return

        ok, msg = export_dataset(
            self.image_dir,
            self.label_dir,
            output_dir,
            self.current_class_names
        )

        if ok:
            self.set_status("状态：数据集导出完成")
            messagebox.showinfo("成功", msg)
        else:
            messagebox.showerror("错误", msg)

    def prev_image(self):
        if not self.image_files:
            return
        if self.current_index > 0:
            self.maybe_autosave()
            self.current_index -= 1
            self.show_current_image()

    def next_image(self):
        if not self.image_files:
            return
        if self.current_index < len(self.image_files) - 1:
            self.maybe_autosave()
            self.current_index += 1
            self.show_current_image()

    def execute_action(self, action_name, **kwargs):
        """
        OpenClaw 分身动作统一入口
        
        参数:
            action_name: 动作名称
            **kwargs: 额外参数（用于带参数的动作）
        
        返回:
            dict: {
                'success': bool,      # 是否成功执行
                'action': str,        # 动作名称
                'message': str,       # 执行结果消息
                'error': str or None  # 错误信息（如果失败）
            }
        """
        # 动作映射表：action_name -> (method, success_message, needs_kwargs)
        action_map = {
            # 基础导航动作
            'prev_image': (
                self.prev_image,
                '已切换到上一张图片',
                False
            ),
            'next_image': (
                self.next_image,
                '已切换到下一张图片',
                False
            ),
            'save_current_labels': (
                self.save_current_labels,
                '已保存当前标注',
                False
            ),
            'delete_selected_box': (
                self.delete_selected_box,
                '已删除选中框',
                False
            ),
            'copy_labels_from_previous_image': (
                self.copy_labels_from_previous_image,
                '已复制上一张图片标注',
                False
            ),
            'run_openclaw_analysis': (
                self.run_openclaw_analysis,
                '已启动 OpenClaw 分析',
                False
            ),
            
            # OpenClaw分身能力扩张v2：无弹窗选框控制
            'select_next_box': (
                self.select_next_box,
                '已选中下一个框',
                False
            ),
            'select_prev_box': (
                self.select_prev_box,
                '已选中上一个框',
                False
            ),
            'select_box_by_index': (
                self.select_box_by_index,
                '已按索引选中框',
                True  # 需要box_index参数
            ),
            'delete_box_by_index': (
                self.delete_box_by_index,
                '已按索引删除框',
                True  # 需要box_index参数
            ),
            'analyze_box_by_index': (
                self.analyze_box_by_index,
                '已按索引分析框',
                True  # 需要box_index参数
            ),
            'edit_box_by_index': (
                self.edit_box_by_index,
                '已按索引打开编辑窗口',
                True  # 需要box_index参数
            ),
            'change_box_class_by_index': (
                self.change_box_class_by_index,
                '已按索引修改框类别',
                True  # 需要box_index和class_name参数
            ),
            
            # OpenClaw分身能力扩张v2第二刀：无弹窗框微调动作
            'move_box_by_index': (
                self.move_box_by_index,
                '已按索引移动框',
                True  # 需要box_index、dx、dy参数
            ),
            'resize_box_by_index': (
                self.resize_box_by_index,
                '已按索引调整框大小',
                True  # 需要box_index、dw、dh参数
            ),
            'nudge_box_by_index': (
                self.nudge_box_by_index,
                '已按索引微调框位置',
                True  # 需要box_index、direction参数，可选amount
            ),
            'set_box_coords_by_index': (
                self.set_box_coords_by_index,
                '已按索引设置框坐标',
                True  # 需要box_index，可选cx、cy、w、h参数
            ),
            
            # OpenClaw分身能力扩张v2：标注批处理增强冲刺包
            'change_all_boxes_class': (
                self.change_all_boxes_class,
                '已批量修改全部框类别',
                True  # 需要target_class参数
            ),
            'change_boxes_class_by_source_class': (
                self.change_boxes_class_by_source_class,
                '已按源类别批量修改框类别',
                True  # 需要source_class和target_class参数
            ),
            'delete_boxes_by_class': (
                self.delete_boxes_by_class,
                '已按类别批量删除框',
                True  # 需要class_name参数
            ),
            'clear_current_image_boxes': (
                self.clear_current_image_boxes,
                '已清空当前图全部标注框',
                False
            ),
            'analyze_all_boxes': (
                self.analyze_all_boxes,
                '已分析全部标注框',
                False
            ),
            'analyze_boxes_by_class': (
                self.analyze_boxes_by_class,
                '已按类别分析标注框',
                True  # 需要class_name参数
            ),
        }
        
        # 检查动作是否支持
        if action_name not in action_map:
            return {
                'success': False,
                'action': action_name,
                'message': f'不支持的动作: {action_name}',
                'error': f'未知动作名称，支持的动作: {", ".join(action_map.keys())}'
            }
        
        # 获取对应的方法、成功消息和参数需求
        method, success_message, needs_kwargs = action_map[action_name]
        
        try:
            # 根据参数需求执行动作
            if needs_kwargs:
                # 需要参数的动作
                result = method(**kwargs)
                # 检查返回结果类型
                if isinstance(result, dict):
                    # 返回字典的动作（如批量处理方法）
                    if result.get('success', False):
                        return {
                            'success': True,
                            'action': action_name,
                            'message': result.get('message', success_message),
                            'error': None,
                            'data': result  # 包含额外的数据
                        }
                    else:
                        return {
                            'success': False,
                            'action': action_name,
                            'message': result.get('message', f'执行动作失败: {action_name}'),
                            'error': result.get('error', '方法返回失败')
                        }
                elif result:
                    # 返回布尔值的动作
                    return {
                        'success': True,
                        'action': action_name,
                        'message': success_message,
                        'error': None
                    }
                else:
                    return {
                        'success': False,
                        'action': action_name,
                        'message': f'执行动作失败: {action_name}',
                        'error': '方法返回False，可能参数无效或条件不满足'
                    }
            else:
                # 不需要参数的动作
                result = method()
                # 检查返回结果类型
                if isinstance(result, dict):
                    # 返回字典的动作
                    if result.get('success', False):
                        return {
                            'success': True,
                            'action': action_name,
                            'message': result.get('message', success_message),
                            'error': None,
                            'data': result
                        }
                    else:
                        return {
                            'success': False,
                            'action': action_name,
                            'message': result.get('message', f'执行动作失败: {action_name}'),
                            'error': result.get('error', '方法返回失败')
                        }
                else:
                    # 无返回值或返回其他类型的动作
                    return {
                        'success': True,
                        'action': action_name,
                        'message': success_message,
                        'error': None
                    }
            
        except Exception as e:
            # 捕获异常，返回错误信息
            return {
                'success': False,
                'action': action_name,
                'message': f'执行动作失败: {action_name}',
                'error': str(e)
            }

