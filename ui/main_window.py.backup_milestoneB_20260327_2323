    # 冲刺目标B：批量删除
    def delete_boxes_by_class(self, class_name):
        """
        批量删除：删除当前图中指定类别的全部框
        
        参数:
            class_name: 要删除的类别名称
        
        返回:
            dict: {
                'success': bool,      # 是否成功
                'deleted_count': int, # 删除的框数量
                'message': str        # 结果消息
            }
        """
        if not self.boxes:
            return {
                'success': False,
                'deleted_count': 0,
                'message': '当前没有标注框'
            }
        
        # 获取类别ID
        class_id = self.get_current_class_id(class_name)
        if class_id is None:
            return {
                'success': False,
                'deleted_count': 0,
                'message': f'无效的类别名称: {class_name}'
            }
        
        # 统计删除数量
        deleted_count = 0
        indices_to_delete = []
        
        # 找出要删除的框索引
        for i in range(len(self.boxes)):
            if self.boxes[i][0] == class_id:
                indices_to_delete.append(i)
        
        # 从后往前删除（避免索引变化）
        for i in sorted(indices_to_delete, reverse=True):
            self.boxes.pop(i)
            deleted_count += 1
            
            # 更新选中索引
            if self.selected_idx == i:
                self.selected_idx = None
            elif self.selected_idx is not None and self.selected_idx > i:
                self.selected_idx -= 1
        
        # 刷新UI
        self.refresh_box_list()
        self.redraw_boxes()
        
        # 如果有选中框，更新信息区
        if self.selected_idx is not None and self.selected_idx < len(self.boxes):
            self.update_selected_box_panel()
        
        message = f'已删除 {deleted_count} 个 {class_name} 类别的框' if deleted_count > 0 else f'未找到 {class_name} 类别的框'
        self.set_status(f"状态：{message}")
        
        return {
            'success': True,
            'deleted_count': deleted_count,
            'message': message
        }

