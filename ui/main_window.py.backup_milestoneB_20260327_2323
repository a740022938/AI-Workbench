    def load_classes_from_file(self, file_path):
        import os

        ext = os.path.splitext(file_path)[1].lower()
        classes = []

        if ext == ".txt":
            with open(file_path, "r", encoding="utf-8") as f:
                classes = [line.strip() for line in f if line.strip()]

        elif ext in [".yaml", ".yml"]:
            try:
                import yaml
            except ImportError:
                messagebox.showerror("导入失败", "当前环境缺少 PyYAML，请先安装 pyyaml")
                return None

            with open(file_path, "r", encoding="utf-8") as f:
                data = yaml.safe_load(f)

            names = data.get("names")
            if isinstance(names, list):
                classes = [str(x).strip() for x in names if str(x).strip()]
            elif isinstance(names, dict):
                for k in sorted(names.keys(), key=lambda x: int(x) if str(x).isdigit() else str(x)):
                    v = str(names[k]).strip()
                    if v:
                        classes.append(v)

        if not classes:
            return None

        return classes

