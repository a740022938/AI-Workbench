    def select_next_box(self):
        """
        选中下一个框（循环选择）
        
        返回:
            bool: 是否成功选中
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if self.selected_idx is None:
            # 如果没有选中框，选中第一个
            new_idx = 0
        else:
            # 选中下一个框，循环到开头
            new_idx = (self.selected_idx + 1) % len(self.boxes)
        
        return self._select_box_by_index(new_idx)

    def select_prev_box(self):
        """
        选中上一个框（循环选择）
        
        返回:
            bool: 是否成功选中
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if self.selected_idx is None:
            # 如果没有选中框，选中最后一个
            new_idx = len(self.boxes) - 1
        else:
            # 选中上一个框，循环到末尾
            new_idx = (self.selected_idx - 1) % len(self.boxes)
        
        return self._select_box_by_index(new_idx)

    def select_box_by_index(self, box_index):
        """
        按索引选中框
        
        参数:
            box_index: 框的索引（0-based）
        
        返回:
            bool: 是否成功选中
        """
        return self._select_box_by_index(box_index)

    def delete_box_by_index(self, box_index):
        """
        按索引删除框
        
        参数:
            box_index: 框的索引（0-based）
        
        返回:
            bool: 是否成功删除
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if not (0 <= box_index < len(self.boxes)):
            self.set_status(f"状态：无效的框索引 {box_index}，有效范围 0-{len(self.boxes)-1}")
            return False
        
        # 获取要删除的框信息
        box = self.boxes[box_index]
        cls_name = self.get_current_class_name(box[0])
        
        # 删除框
        self.boxes.pop(box_index)
        
        # 更新选中索引
        if self.selected_idx == box_index:
            self.selected_idx = None
        elif self.selected_idx is not None and self.selected_idx > box_index:
            # 如果选中的框在删除框之后，索引减1
            self.selected_idx -= 1
        
        # 刷新UI
        self.refresh_box_list()
        self.redraw_boxes()
        self.set_status(f"状态：已删除框 #{box_index}（类别: {cls_name}），当前剩余 {len(self.boxes)} 个框")
        
        return True

    def analyze_box_by_index(self, box_index):
        """
        按索引分析框（调用OpenClaw分析）
        
        参数:
            box_index: 框的索引（0-based）
        
        返回:
            bool: 是否成功分析
        """
        if not self.boxes:
            self.set_status("状态：当前没有标注框")
            return False
        
        if not (0 <= box_index < len(self.boxes)):
            self.set_status(f"状态：无效的框索引 {box_index}，有效范围 0-{len(self.boxes)-1}")
            return False
        
        # 先选中该框
        if not self._select_box_by_index(box_index):
            return False
        
        # 调用OpenClaw分析选中框
        try:
            # 使用现有的run_openclaw_analysis方法
            self.run_openclaw_analysis()
            return True
        except Exception as e:
            self.set_status(f"状态：分析框 #{box_index} 时出错: {str(e)}")
