    def copy_labels_from_previous_image(self):
        """复制上一张图片的标注到当前图片"""
        if not self.image_files:
            messagebox.showinfo("提示", "当前没有图片")
            return
        
        if self.current_index == 0:
            messagebox.showinfo("提示", "没有上一张图片")
            return
        
        # 获取上一张图片名和标签路径
        prev_image_name = self.image_files[self.current_index - 1]
        prev_label_path = self.get_label_path(prev_image_name)
        
        if not os.path.exists(prev_label_path):
            messagebox.showinfo("提示", "上一张图片没有标注")
            return
        
        # 读取上一张图片的标注
        prev_boxes = []
        try:
            with open(prev_label_path, "r", encoding="utf-8") as f:
                for line in f:
                    parts = line.strip().split()
                    if len(parts) < 5:
                        continue
                    cls_id = int(float(parts[0]))
                    cx = float(parts[1]); cy = float(parts[2]); bw = float(parts[3]); bh = float(parts[4])
                    prev_boxes.append([cls_id, cx, cy, bw, bh])
        except Exception as e:
            messagebox.showerror("错误", f"读取上一张标注失败：\n{e}")
            return
        
        if not prev_boxes:
            messagebox.showinfo("提示", "上一张图片没有标注框")
            return
        
        # 处理当前图片已有标注的情况
        if self.boxes:
            choice = messagebox.askyesnocancel("复制标注", 
                f"上一张图片有 {len(prev_boxes)} 个标注框\n"
                f"当前图片已有 {len(self.boxes)} 个标注框\n\n"
                "选择操作：\n"
                "是(Y) - 追加标注框\n"
                "否(N) - 替换当前标注框\n"
                "取消 - 放弃操作")
            
            if choice is None:  # 取消
                return
            elif choice:  # 是 - 追加
                self.boxes.extend(prev_boxes)
                self.set_status(f"状态：已追加 {len(prev_boxes)} 个标注框")
            else:  # 否 - 替换
                self.boxes = prev_boxes
                self.set_status(f"状态：已替换为 {len(prev_boxes)} 个标注框")
        else:
            # 当前没有标注，直接复制
            self.boxes = prev_boxes
            self.set_status(f"状态：已复制 {len(prev_boxes)} 个标注框")
        
        # 刷新界面
        self.selected_idx = None
        self.refresh_box_list()
        self.redraw_boxes()

